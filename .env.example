# OpenWeather API key - create one at https://home.openweathermap.org/api_keys
# (new keys can take a couple of hours to activate)
#
# Locally: copy this file to .env.local and fill in the key.
# On Vercel: set it in Project Settings → Environment Variables,
# then `vercel env pull .env.local` keeps local dev in sync.
OPENWEATHER_API_KEY=
